# -----------------------------------------------------------------------
# EEG Biometric Authentication — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# -----------------------------------------------------------------------

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=eeg_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=eeg_biometric

# --- MySQL Docker Config (docker-compose only) ---
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=eeg_biometric
MYSQL_USER=eeg_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_PORT=3306

# --- Service Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=80

# --- API Security ---
# Comma-separated allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Set a strong random string to enforce X-API-Key header on all requests.
# Leave blank to disable (not recommended for production).
API_KEY=

# --- EEG Signal Processing ---
# Mains frequency for notch filter: 50 for India/EU, 60 for USA/Canada
NOTCH_FREQ=50
# Default authentication confidence threshold (0.0 – 1.0)
AUTH_THRESHOLD=0.90
# Max raw samples accepted per hardware POST request (safety cap)
# 30720 = 120 seconds at 256 Hz
MAX_HARDWARE_SAMPLES=30720
